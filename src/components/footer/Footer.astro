---
/**
 * Footer.astro — three-column footer with nav, brand, socials
 */
import { type Locale, ui, localizedPath } from '~/i18n';
import { site } from '~/data/site';
import { navItems } from '~/data/nav';
import Beian from './Beian.astro';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = ui(lang);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container-wide footer-inner">
    <div class="footer-col">
      <div class="footer-brand">橘子的皮</div>
      <p class="footer-tagline">{t('site.tagline')}</p>
      <div class="footer-socials">
        <a href={site.socials.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
          </svg>
        </a>
        <a href={site.socials.gitee} target="_blank" rel="noopener noreferrer" aria-label="Gitee">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M11.985 0C5.403 0 .06 5.343.06 11.925c0 6.582 5.343 11.925 11.925 11.925 6.582 0 11.925-5.343 11.925-11.925C23.91 5.343 18.567 0 11.985 0zm.015 22.95c-6.072 0-11.04-4.968-11.04-11.04S5.928.87 12 .87s11.04 4.968 11.04 11.04c0 6.072-4.95 11.04-11.04 11.04z"/>
          </svg>
        </a>
        <a href={localizedPath('/rss.xml', lang)} aria-label="RSS">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20 5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z" />
          </svg>
        </a>
      </div>
    </div>

    <div class="footer-col">
      <h4 class="footer-heading">{t('nav.home')}</h4>
      <ul class="footer-list">
        {navItems.map((item) => (
          <li>
            <a href={localizedPath(item.href, lang)} data-astro-prefetch>{t(item.key)}</a>
          </li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h4 class="footer-heading">Elsewhere</h4>
      <ul class="footer-list">
        <li><a href={site.socials.github} target="_blank" rel="noopener noreferrer">GitHub</a></li>
        <li><a href={site.socials.gitee} target="_blank" rel="noopener noreferrer">Gitee</a></li>
        <li><a href={site.socials.juejin} target="_blank" rel="noopener noreferrer">Juejin</a></li>
        <li><a href={site.email}>{site.email.replace('mailto:', '')}</a></li>
      </ul>
    </div>
  </div>

  <div class="container-wide footer-bottom">
    <div class="footer-meta">
      <span>© {year} {site.title}. {t('footer.allRights')}.</span>
      <span class="footer-sep">·</span>
      <span>{t('footer.builtWith')} <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a></span>
      <span class="footer-sep">·</span>
      <Beian />
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    border-top: 1px solid var(--color-border-subtle);
    padding-top: 3rem;
    padding-bottom: 2rem;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 2.5rem;
  }
  .footer-brand {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-fg);
    margin-bottom: 0.5rem;
  }
  .footer-tagline {
    color: var(--color-fg-muted);
    font-size: var(--text-sm);
    margin: 0 0 1.25rem;
    line-height: 1.6;
  }
  .footer-socials {
    display: inline-flex;
    gap: 0.75rem;
  }
  .footer-socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: var(--radius-md);
    color: var(--color-fg-muted);
    background: var(--color-bg-subtle);
    transition: color var(--duration-fast) var(--ease-out-soft),
                background var(--duration-fast) var(--ease-out-soft);
  }
  .footer-socials a:hover {
    color: var(--color-fg);
    background: var(--color-border-subtle);
  }
  .footer-heading {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-fg);
    margin: 0 0 1rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .footer-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer-list a {
    color: var(--color-fg-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: color var(--duration-fast) var(--ease-out-soft);
  }
  .footer-list a:hover { color: var(--color-fg); }
  .footer-bottom {
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border-subtle);
  }
  .footer-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-fg-subtle);
    font-size: var(--text-xs);
  }
  .footer-meta a {
    color: var(--color-fg-muted);
    text-decoration: none;
  }
  .footer-meta a:hover { color: var(--color-fg); text-decoration: underline; text-underline-offset: 3px; }
  .footer-sep { opacity: 0.5; }
  @media (max-width: 720px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
