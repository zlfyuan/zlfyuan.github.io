---
/**
 * PostMeta.astro — date, reading time, word count, tags
 */
import { type Locale, ui } from '~/i18n';
import { formatDate } from '~/lib/format-date';

interface Props {
  date: Date;
  updated?: Date;
  minutes: number;
  words: number;
  tags: string[];
  lang: Locale;
}
const { date, updated, minutes, words, lang } = Astro.props;
const t = ui(lang);
---

<div class="post-meta">
  <span class="meta-item">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="4" width="18" height="18" rx="2" />
      <line x1="16" y1="2" x2="16" y2="6" />
      <line x1="8" y1="2" x2="8" y2="6" />
      <line x1="3" y1="10" x2="21" y2="10" />
    </svg>
    <time datetime={date.toISOString()}>{formatDate(date, lang)}</time>
  </span>
  <span class="meta-sep">·</span>
  <span class="meta-item">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="10" />
      <polyline points="12 6 12 12 16 14" />
    </svg>
    {minutes} {t('post.minutes')}
  </span>
  <span class="meta-sep">·</span>
  <span class="meta-item">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
      <polyline points="14 2 14 8 20 8" />
    </svg>
    {words} {t('post.words')}
  </span>
  {updated && (
    <>
      <span class="meta-sep">·</span>
      <span class="meta-item">
        {t('post.updatedOn')}: {formatDate(updated, lang)}
      </span>
    </>
  )}
</div>

<style>
  .post-meta {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: var(--color-fg-muted);
    font-size: var(--text-sm);
  }
  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .meta-sep {
    opacity: 0.5;
  }
</style>
