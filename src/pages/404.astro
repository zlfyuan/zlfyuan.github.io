---
/**
 * 404 page — bilingual fallback
 */
import { getLocaleFromUrl, ui } from '~/i18n';
import BaseLayout from '~/layouts/BaseLayout.astro';

const lang = getLocaleFromUrl(Astro.url);
const t = ui(lang);
---

<BaseLayout title="404" path="/404" noindex>
  <section class="error container-prose">
    <p class="error-code">404</p>
    <h1 class="error-title">{t('404.title')}</h1>
    <p class="error-desc">{t('404.description')}</p>
    <a href={`/${lang}/`} class="btn btn-primary" data-astro-prefetch>
      ← {t('404.back')}
    </a>
  </section>
</BaseLayout>

<style>
  .error {
    padding-block: 8rem 6rem;
    text-align: center;
  }
  .error-code {
    margin: 0 0 1rem;
    font-size: clamp(5rem, 14vw, 9rem);
    font-weight: 700;
    letter-spacing: -0.05em;
    background: linear-gradient(135deg, var(--color-accent), color-mix(in oklch, var(--color-accent) 50%, transparent));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    line-height: 1;
  }
  .error-title {
    margin: 0 0 1rem;
    font-size: var(--text-3xl);
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .error-desc {
    margin: 0 0 2rem;
    color: var(--color-fg-muted);
    font-size: var(--text-lg);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: background var(--duration-fast) var(--ease-out-soft);
  }
  .btn-primary {
    background: var(--color-accent);
    color: var(--color-accent-fg);
  }
  .btn-primary:hover {
    background: var(--color-accent-hover);
  }
</style>
