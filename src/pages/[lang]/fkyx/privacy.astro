---
/**
 * 发疯一下 · 隐私协议
 * Skeleton placeholder — replace <Fragment slot="body"> with full content.
 */
import { LOCALES, type Locale, ui } from '~/i18n';
import DocLayout from '~/layouts/DocLayout.astro';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = (Astro.params.lang as Locale) ?? 'zh-CN';
const t = ui(lang);
const title = t('doc.privacy.title');
const placeholder = t('doc.placeholder.notice');
---

<DocLayout
  kind="privacy"
  title={title}
  appName="发疯一下"
  path="/fkyx/privacy/"
  description={`发疯一下 ${title}`}
>
  <div class="placeholder-notice">
    <strong>⚠ {placeholder}</strong>
    <p>
      请将完整正文从
      <a href="https://docs.qq.com/doc/DSnZyd2xFanFIck1N" target="_blank" rel="noopener noreferrer">腾讯文档原文</a>
      复制粘贴到 <code>src/pages/[lang]/fkyx/privacy.astro</code> 中，覆盖此占位区。
    </p>
  </div>

  <h2>1. 引言</h2>
  <p>
    欢迎使用 <strong>发疯一下</strong>（以下简称"本应用"）。本应用尊重并保护所有使用服务用户的个人隐私权。
    为了给您提供更准确、更有个性化的服务，本应用会按照本隐私权政策的规定使用和披露您的个人信息。
  </p>

  <h2>2. 适用范围</h2>
  <p>（待补充）</p>

  <h2>3. 信息使用</h2>
  <p>（待补充）</p>

  <h2>4. 信息披露</h2>
  <p>（待补充）</p>

  <h2>5. 信息存储和交换</h2>
  <p>（待补充）</p>

  <h2>6. Cookie 与同类技术</h2>
  <p>（待补充）</p>

  <h2>7. 本隐私政策的修改</h2>
  <p>（待补充）</p>

  <h2>8. 联系我们</h2>
  <p>（待补充）</p>
</DocLayout>

<style>
  .placeholder-notice {
    padding: 1rem 1.25rem;
    margin-bottom: 2rem;
    background: color-mix(in oklch, var(--color-accent) 8%, transparent);
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    line-height: 1.7;
  }
  .placeholder-notice strong { display: block; margin-bottom: 0.4rem; }
  .placeholder-notice code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    padding: 0.1em 0.4em;
    background: var(--color-bg);
    border-radius: var(--radius-xs);
  }
</style>
