---
/**
 * Single tag page — all posts tagged with [tag]
 */
import { getCollection } from 'astro:content';
import { LOCALES, type Locale, ui } from '~/i18n';
import BaseLayout from '~/layouts/BaseLayout.astro';
import PostCard from '~/components/post/PostCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return LOCALES.flatMap((lang) => {
    const filtered = posts.filter((p) => p.data.lang === lang);
    const tagSet = new Set<string>();
    for (const post of filtered) for (const tag of post.data.tags) tagSet.add(tag);
    return Array.from(tagSet).map((tag) => ({
      params: { lang, tag },
      props: { tag, lang },
    }));
  });
}

const { tag, lang } = Astro.props as { tag: string; lang: Locale };
const t = ui(lang);
const posts = (await getCollection('blog', ({ data }) =>
  data.lang === lang && !data.draft && data.tags.includes(tag)
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title={`#${tag}`}
  description={`${posts.length} ${t('tags.count')}`}
 
  path={`/tags/${encodeURIComponent(tag)}/`}
>
  <section class="container-wide tag-page">
    <header class="page-head">
      <a href={`/${lang}/tags/`} class="back-link" data-astro-prefetch>← {t('tags.title')}</a>
      <h1 class="page-title">#{tag}</h1>
      <p class="page-subtitle">{posts.length} {t('tags.count')}</p>
    </header>
    <div class="post-list">
      {posts.map((post) => <PostCard post={post} lang={lang} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .tag-page {
    padding-block: 4rem 6rem;
  }
  .page-head {
    text-align: center;
    margin-bottom: 3rem;
  }
  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--color-fg-muted);
    font-size: var(--text-sm);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-soft);
  }
  .back-link:hover { color: var(--color-fg); }
  .page-title {
    margin: 0 0 0.5rem;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    font-family: var(--font-mono);
  }
  .page-subtitle {
    margin: 0;
    color: var(--color-fg-muted);
    font-size: var(--text-base);
  }
  .post-list {
    max-width: 56rem;
    margin-inline: auto;
  }
</style>
