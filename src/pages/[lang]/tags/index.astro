---
/**
 * Tags index — all tags with counts
 */
import { getCollection } from 'astro:content';
import { LOCALES, type Locale, ui } from '~/i18n';
import BaseLayout from '~/layouts/BaseLayout.astro';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = (Astro.params.lang as Locale) ?? 'zh-CN';
const t = ui(lang);
const posts = await getCollection('blog', ({ data }) => data.lang === lang && !data.draft);
const counts = posts.reduce<Record<string, number>>((acc, post) => {
  for (const tag of post.data.tags) acc[tag] = (acc[tag] ?? 0) + 1;
  return acc;
}, {});
const tags = Object.entries(counts).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title={t('tags.title')} path="/tags/">
  <section class="container-prose tags">
    <header class="page-head">
      <h1 class="page-title">{t('tags.title')}</h1>
      <p class="page-subtitle">{tags.length} {t('tags.count')}</p>
    </header>
    <ul class="tag-cloud">
      {tags.map(([tag, count]) => (
        <li>
          <a href={`/${lang}/tags/${encodeURIComponent(tag)}/`} class="tag-pill" data-astro-prefetch>
            <span class="tag-name">#{tag}</span>
            <span class="tag-count">{count}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .tags {
    padding-block: 4rem 6rem;
  }
  .page-head {
    text-align: center;
    margin-bottom: 3rem;
  }
  .page-title {
    margin: 0 0 0.75rem;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
  }
  .page-subtitle {
    margin: 0;
    color: var(--color-fg-muted);
    font-size: var(--text-base);
  }
  .tag-cloud {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    justify-content: center;
  }
  .tag-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.875rem;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    color: var(--color-fg);
    text-decoration: none;
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    transition: background var(--duration-fast) var(--ease-out-soft),
                border-color var(--duration-fast) var(--ease-out-soft),
                transform var(--duration-fast) var(--ease-out-soft);
  }
  .tag-pill:hover {
    background: var(--color-accent);
    color: var(--color-accent-fg);
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  .tag-count {
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
    background: var(--color-bg);
    padding: 0.1em 0.5em;
    border-radius: 999px;
  }
  .tag-pill:hover .tag-count {
    background: color-mix(in oklch, var(--color-accent-fg) 20%, transparent);
    color: var(--color-accent-fg);
  }
</style>
